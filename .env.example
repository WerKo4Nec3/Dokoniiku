NEXT_PUBLIC_OPENWEATHER_API_KEY=

# Optional: account + Google sign-in + cloud-saved places (Firebase).
# Leave blank to run without accounts. These values are public web config,
# not secrets — copy them from your Firebase project settings.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: AI place insight via Gemini (server-side route /api/place-insight).
# GEMINI_API_KEY is a real secret — server-only, never expose it to the client.
# Set NEXT_PUBLIC_GEMINI_ENABLED=true to show the "ask AI" button.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
NEXT_PUBLIC_GEMINI_ENABLED=
